{
  "id": null,
  "uid": "synmind-monitoring",
  "title": "SynMind AI - Cognitive Monitoring",
  "tags": ["inovexa", "synmind", "ai", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "style": "dark",
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "AI Cognitive Load (%)",
      "targets": [
        { "expr": "synmind_ai_cognitive_load", "legendFormat": "Cognitive Load" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "stat",
      "title": "Response Latency (ms)",
      "targets": [
        { "expr": "synmind_ai_latency_ms", "legendFormat": "Latency" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "gauge",
      "title": "SynMind Operational Uptime (s)",
      "targets": [
        { "expr": "synmind_ai_uptime_seconds", "legendFormat": "Uptime" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 }
    },
    {
      "type": "table",
      "title": "System Diagnostics",
      "targets": [
        { "expr": "synmind_ai_status_info" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 }
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "30m", "1h"]
  },
  "editable": true
}
